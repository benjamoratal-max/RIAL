# Environment variables for RIAL App

# Database
DATABASE_URL="file:./prisma/dev.db"

# JWT Secret (change in production!)
JWT_SECRET=dev_secret_change_me_in_production

# Server
PORT=3000
NODE_ENV=development

# CORS Origins (comma-separated). En producción incluye tu dominio Vercel:
# CORS_ORIGINS=https://tu-app.vercel.app,https://www.tudominio.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# URL del frontend (Vercel) — también se permiten automáticamente *.vercel.app
# FRONTEND_URL=https://tu-app.vercel.app

# Email (SMTP)
# For Gmail, you need to create an App Password: https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu-email@gmail.com
SMTP_PASS=tu-contraseÃ±a-de-aplicaciÃ³n
SMTP_FROM=noreply@rial.com

# SMS (Twilio)
# Get your credentials from: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=tu-account-sid
TWILIO_AUTH_TOKEN=tu-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# reCAPTCHA (opcional; si no se configura, el login no exige captcha)
# Obtén las claves en: https://www.google.com/recaptcha/admin
# RECAPTCHA_SECRET_KEY=tu-secret-key-backend

# Optional: Public URLs for ngrok/tunneling
# PUBLIC_BACKEND_URL=https://your-backend.ngrok.io
# PUBLIC_FRONTEND_URL=https://your-frontend.ngrok.io

# RentCast (real Miami rental listings)
# Create key: https://www.rentcast.io -> API Dashboard
RENTCAST_API_KEY=tu_api_key_real

# Google Calendar (OAuth 2.0 — brokers conectan su calendario)
# Consola: https://console.cloud.google.com/apis/credentials
# Redirect URI autorizada (debe coincidir exactamente):
#   http://localhost:3000/api/calendar/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/calendar/auth/google/callback

# === Stripe (pagos con tarjeta) ===
# Si NO definís STRIPE_SECRET_KEY, el cobro de reservas corre en modo SIMULADO
# (no se cobra nada). Al pegar las claves, el cobro real con tarjeta se activa solo.
#
# 1) Creá una cuenta gratis en https://stripe.com y entrá en modo Test.
# 2) Claves en: https://dashboard.stripe.com/test/apikeys
#      STRIPE_SECRET_KEY      → "Secret key"      (empieza con sk_test_...)
#      STRIPE_PUBLISHABLE_KEY → "Publishable key" (pk_test_...; opcional con Checkout)
# 3) Webhook signing secret (whsec_...):
#    - En local: `npm run dev` inicia automáticamente `stripe listen` si tenés el
#      Stripe CLI instalado (winget install Stripe.StripeCli). La primera vez que
#      corras listen, copiá el whsec_... que imprime a STRIPE_WEBHOOK_SECRET.
#    - En producción: creá el endpoint en https://dashboard.stripe.com/test/webhooks
#      apuntando a https://TU-BACKEND/api/payments/stripe/webhook (evento
#      checkout.session.completed) y pegá ese whsec_... en Render.
#
# Desarrollo local: con solo `npm run dev` alcanza. Al volver de Stripe Checkout el
# pago se confirma al instante vía session_id; el webhook es respaldo adicional.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# === Web Push (notificaciones al dispositivo, p. ej. avisar al broker) ===
# Si faltan las claves VAPID, el push se desactiva y solo quedan las notificaciones
# in-app (campanita). Generá un par con:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
# Usá EL MISMO par en local y en producción (Render).
# VAPID_PUBLIC_KEY=...
# VAPID_PRIVATE_KEY=...
# VAPID_SUBJECT=mailto:soporte@rial.com

# Environment variables for RIAL App

# Database
DATABASE_URL="file:./prisma/dev.db"

# JWT Secret (change in production!)
JWT_SECRET=dev_secret_change_me_in_production

# Server
PORT=3000
NODE_ENV=development

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Email (SMTP)
# For Gmail, you need to create an App Password: https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu-email@gmail.com
SMTP_PASS=tu-contraseÃ±a-de-aplicaciÃ³n
SMTP_FROM=noreply@rial.com

# SMS (Twilio)
# Get your credentials from: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=tu-account-sid
TWILIO_AUTH_TOKEN=tu-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# reCAPTCHA (opcional; si no se configura, el login no exige captcha)
# Obtén las claves en: https://www.google.com/recaptcha/admin
# RECAPTCHA_SECRET_KEY=tu-secret-key-backend

# Optional: Public URLs for ngrok/tunneling
# PUBLIC_BACKEND_URL=https://your-backend.ngrok.io
# PUBLIC_FRONTEND_URL=https://your-frontend.ngrok.io

# RentCast (real Miami rental listings)
# Create key: https://www.rentcast.io -> API Dashboard
RENTCAST_API_KEY=tu_api_key_real

# ==========================================================================
#  RIAL backend - variables de producción (VM Oracle)
#  Copiá este archivo a  .env.production  y completá los valores reales.
#  NUNCA lo subas al repo con secretos (ya está ignorado por git).
# ==========================================================================

# ---- Postgres (contenedor db) ----
POSTGRES_USER=rial
POSTGRES_PASSWORD=cambia_esto_por_algo_largo_y_aleatorio
POSTGRES_DB=rial

# DATABASE_URL/DIRECT_URL apuntan al servicio `db` por la red interna de compose.
# Usá EXACTAMENTE el mismo user/password/db de arriba.
DATABASE_URL=postgresql://rial:cambia_esto_por_algo_largo_y_aleatorio@db:5432/rial?schema=public
DIRECT_URL=postgresql://rial:cambia_esto_por_algo_largo_y_aleatorio@db:5432/rial?schema=public

# ---- App ----
NODE_ENV=production
PORT=3000
# Generá uno con:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=pega_aqui_un_secreto_fuerte

# Dominios del frontend permitidos por CORS (coma-separados). El front real + www.
CORS_ORIGINS=https://rialstateai.com,https://www.rialstateai.com
FRONTEND_URL=https://rialstateai.com

# ---- Email (SMTP) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu-email@gmail.com
SMTP_PASS=tu-app-password
SMTP_FROM=noreply@rialstateai.com

# ---- RentCast (listings reales de Miami) ----
RENTCAST_API_KEY=

# ---- Google Calendar OAuth (brokers) ----
# OJO: actualizá la "Authorized redirect URI" en Google Cloud Console para que sea
# EXACTAMENTE esta, o el connect del calendario falla.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.rialstateai.com/api/calendar/auth/google/callback

# ---- Stripe (pagos) ----
# Sin STRIPE_SECRET_KEY el cobro corre en modo simulado. Para cobro real, pegá las claves
# y configurá el webhook en Stripe apuntando a:
#   https://api.rialstateai.com/api/payments/stripe/webhook  (evento checkout.session.completed)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- Web Push (VAPID) ----
# Usá EL MISMO par que ya tenías en Render (si cambian, se invalidan las suscripciones).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:soporte@rialstateai.com

# ---- reCAPTCHA (opcional) ----
RECAPTCHA_SECRET_KEY=

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  password  String
  role      String
  properties Property[]
  bookings   Booking[]
  reviews    Review[]
  aiInteractions AIInteraction[]
}

model Property {
  id          Int       @id @default(autoincrement())
  title       String
  description String
  price       Float
  location    String
  images      String    // JSON array stored as string
  ownerId     Int
  owner       User      @relation(fields: [ownerId], references: [id])
  bookings    Booking[]
  reviews     Review[]
}

model Booking {
  id         Int      @id @default(autoincrement())
  userId     Int
  propertyId Int
  startDate  DateTime
  endDate    DateTime
  user       User     @relation(fields: [userId], references: [id])
  property   Property @relation(fields: [propertyId], references: [id])
}

model Review {
  id         Int      @id @default(autoincrement())
  rating     Int
  comment    String
  userId     Int
  propertyId Int
  user       User     @relation(fields: [userId], references: [id])
  property   Property @relation(fields: [propertyId], references: [id])
}

model AIInteraction {
  id            String    @id @default(cuid())
  userId        Int?
  question      String
  answer        String
  helpful       Boolean?
  improvedAnswer String?
  category      String    @default("general")
  intent        String?
  metadata      String?   // JSON string
  knowledgeId   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User?     @relation(fields: [userId], references: [id])
  
  @@index([category])
  @@index([helpful])
  @@index([userId])
  @@index([knowledgeId])
}

model AIConfigVersion {
  id            String    @id @default(cuid())
  version       Int       @default(1)
  configType    String    // 'prompt', 'rule', 'threshold', 'parameter'
  configKey     String    // Clave única de la configuración
  configValue   String    // JSON string con el valor
  previousValue String?   // JSON string con valor anterior (para rollback)
  changeReason  String?   // Razón del cambio (feedback, pattern, etc.)
  validationStatus String @default("pending") // 'pending', 'validated', 'rejected'
  testResults   String?   // JSON string con resultados de tests
  appliedAt     DateTime?
  rolledBackAt  DateTime?
  isActive      Boolean   @default(false)
  safetyScore   Float?    // Puntuación de seguridad (0-1)
  changeSource  String    @default("auto") // 'auto', 'manual', 'feedback'
  metadata      String?   // JSON string con metadata adicional
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@unique([configType, configKey, version])
  @@index([configType, configKey])
  @@index([isActive])
  @@index([validationStatus])
  @@index([safetyScore])
}

model AIRule {
  id            String    @id @default(cuid())
  ruleName      String
  pattern       String    // Patrón de pregunta/respuesta
  response      String    // Respuesta o template
  confidence    Float     @default(0.5) // 0-1
  usageCount    Int       @default(0)
  successRate   Float     @default(0.0) // 0-1
  isActive      Boolean   @default(true)
  isAutoGenerated Boolean  @default(false)
  generatedFrom String?   // ID de interacción que generó esta regla
  metadata      String?   // JSON string
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@index([isActive])
  @@index([confidence])
  @@index([successRate])
  @@index([isAutoGenerated])
}
